{
  "name": "rwns",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "Jacek Kopecky <jacek@jacek.cz>",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "start": "vite --host 0.0.0.0",
    "build": "VITE_BUILD_VERSION=`/bin/echo -n $(date '+%Y-%m-%d %H:%M') \"($(git rev-parse --short HEAD))\"` vite build",
    "build-and-commit": "test -z \"`git status --porcelain --untracked-files=no`\" && npm run build && git add docs && git commit -m ':rocket:' || echo 'FAILED: something not right'",
    "test": "npm run lint && npm run type-check && vitest run",
    "type-check": "tsc --noEmit",
    "lint": "eslint --ext .ts,.tsx src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.183.1",
    "eslint": "^10.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@tweenjs/tween.js": "^25.0.0",
    "seedrandom": "^3.0.5",
    "three": "^0.183.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
